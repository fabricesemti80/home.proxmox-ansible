#!/usr/bin/env bash
set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "usage: mise run role-apply <ansible-tag> [-- <extra ansible-playbook args>]" >&2
  exit 1
fi

tag="$1"
shift

if [[ "${1:-}" == "--" ]]; then
  shift
fi

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

"$script_dir/run-site" --tags "$tag" "$@"
